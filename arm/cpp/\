all: firmware.elf
	arm-none-eabi-objcopy -O binary firmware.elf firmware.bin

firmware.elf: startup.o init.o main.o arm32_aeabi_divmod.o arm32_aeabi_divmod_a32.o
	arm-none-eabi-ld -T qemuboot.ld  -z noexecstack startup.o init.o main.o arm32_aeabi_divmod.o arm32_aeabi_divmod_a32.o -L/home/ros/.local/arm-gnu-toolchain-12.2/arm-none-eabi/lib -lc_nano -o firmware.elf

arm32_aeabi_divmod.o:
	arm-none-eabi-gcc -O0 -g -fno-stack-protector -mthumb -fno-exceptions -c arm32_aeabi_divmod.c -I./include -o arm32_aeabi_divmod.o
	
main.o:
	arm-none-eabi-g++ -O0 -g -fno-stack-protector -mthumb -fno-exceptions -specs=nano.specs -specs=nosys.specs -c main.cpp -I/home/ros/.local/arm-gnu-toolchain-12.2/arm-none-eabi/include -o main.o

arm32_aeabi_divmod_a32.o:
	arm-none-eabi-gcc -O0 -g -fno-stack-protector -c arm32_aeabi_divmod_a32.S -I./include -o arm32_aeabi_divmod_a32.o

startup.o:
	arm-none-eabi-as -c startup.s -o startup.o

init.o:
	arm-none-eabi-g++ -O0 -g -fno-exceptions -c init.cpp -o init.o

clean:
	(rm -f *.o)
	(rm -f *.elf)
	(rm -f *.bin)
	
run:
	qemu-system-arm -M stm32vldiscovery -kernel firmware.bin
	#qemu-system-arm -M versatilepb -nographic -kernel firmware.bin

run-debug:
	qemu-system-arm -s -S -M versatilepb -nographic -kernel firmware.bin

debug:
	arm-none-eabi-gdb --eval-command="target remote localhost:1234"

